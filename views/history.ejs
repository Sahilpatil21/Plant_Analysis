<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Plant Analysis History - PlantScan</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
</head>
<body class="min-h-screen bg-cover bg-center bg-fixed bg-no-repeat" style="background-image: url('https://images.unsplash.com/photo-1501004318641-b39e6451bec6?auto=format&fit=crop&w=1600&q=80');">
    <div class="min-h-screen bg-black/40 backdrop-blur-sm flex items-start md:items-center justify-center px-4 py-10">
        <div class="w-full max-w-6xl bg-white/90 rounded-2xl shadow-2xl p-6 md:p-10">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between border-b border-green-200 pb-5 mb-6 gap-4">
                <div class="flex items-center gap-3">
                    <span class="text-3xl text-green-600"><i class="fas fa-leaf"></i></span>
                    <div>
                        <h1 class="text-2xl md:text-3xl font-bold text-gray-800">My Plant Analysis History</h1>
                        <p class="text-sm text-gray-500">Review and manage all your past plant scans.</p>
                    </div>
                </div>
                <div class="flex gap-3">
                    <a href="/analyze" class="inline-flex items-center px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-600 text-white text-sm font-medium shadow-md">
                        <i class="fas fa-search mr-2"></i> New Analysis
                    </a>
                    <a href="/logout" class="inline-flex items-center px-4 py-2 rounded-lg bg-red-500 hover:bg-red-600 text-white text-sm font-medium shadow-md">
                        <i class="fas fa-sign-out-alt mr-2"></i> Logout
                    </a>
                </div>
            </div>

        <% if (analyses.length === 0) { %>
            <div class="text-center py-16 text-gray-600">
                <i class="fas fa-seedling text-5xl mb-4 text-green-400"></i>
                <p class="text-lg">No plant analyses yet. Start by analyzing your first plant!</p>
            </div>
        <% } else { %>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <% analyses.forEach(analysis => { %>
                    <div class="bg-gradient-to-br from-green-50 to-emerald-50 border border-green-200 rounded-xl overflow-hidden shadow hover:shadow-lg transition-transform hover:-translate-y-1">
                        <img src="<%= analysis.imageData %>" alt="<%= analysis.plantName %>" class="w-full h-48 object-cover">
                        
                        <div class="p-4 flex flex-col gap-3">
                            <div>
                                <div class="text-lg font-semibold text-gray-800"><%= analysis.plantName %></div>
                                <div class="text-xs text-gray-500 flex items-center gap-2">
                                    <i class="fas fa-calendar"></i>
                                    <span><%= new Date(analysis.analyzedAt).toLocaleDateString() %></span>
                                </div>
                            </div>
                            <div class="flex flex-wrap items-center gap-2">
                                <span class="px-2 py-1 rounded-full text-[11px] font-semibold uppercase
                                    <% if (analysis.healthStatus === 'healthy') { %> bg-green-100 text-green-700 <% } %>
                                    <% if (analysis.healthStatus === 'needs-care') { %> bg-yellow-100 text-yellow-700 <% } %>
                                    <% if (analysis.healthStatus === 'unhealthy') { %> bg-red-100 text-red-700 <% } %>
                                    <% if (analysis.healthStatus === 'unknown') { %> bg-gray-100 text-gray-700 <% } %>">
                                    <%= analysis.healthStatus.replace('-', ' ') %>
                                </span>
                                <span class="px-2 py-1 rounded-full text-[11px] bg-blue-50 text-blue-700">
                                    <%= analysis.language === 'marathi' ? 'मराठी' : 'English' %>
                                </span>
                            </div>
                            <div class="flex gap-2 mt-2">
                                <button class="flex-1 inline-flex items-center justify-center px-3 py-2 rounded-lg bg-blue-500 hover:bg-blue-600 text-white text-sm font-medium" onclick="viewAnalysis('<%= analysis._id %>')">
                                    <i class="fas fa-eye mr-1"></i> View
                                </button>
                                <button class="flex-1 inline-flex items-center justify-center px-3 py-2 rounded-lg bg-red-500 hover:bg-red-600 text-white text-sm font-medium" onclick="deleteAnalysis('<%= analysis._id %>')">
                                    <i class="fas fa-trash mr-1"></i> Delete
                                </button>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } %>
    </div>

    <!-- Modal for viewing analysis details -->
    <div id="analysisModal" class="fixed inset-0 hidden bg-black/50 z-50 flex items-center justify-center px-4">
        <div class="bg-white rounded-2xl max-w-2xl w-full max-h-[80vh] overflow-y-auto shadow-2xl p-6 relative">
            <button class="absolute top-3 right-3 text-gray-400 hover:text-gray-600 text-2xl" onclick="closeModal()">&times;</button>
            <div id="modalBody"></div>
        </div>
    </div>

    <script>
        async function viewAnalysis(id) {
            try {
                const response = await fetch(`/api/analysis/${id}`);
                const analysis = await response.json();
                
                const modalBody = document.getElementById('modalBody');
                modalBody.innerHTML = `
                    <h2 class="text-2xl font-bold text-gray-800 mb-3">${analysis.plantName}</h2>
                    <img src="${analysis.imageData}" alt="${analysis.plantName}" class="w-full max-h-80 object-contain rounded-lg mb-4">
                    <div class="whitespace-pre-wrap text-sm leading-relaxed text-gray-700 border-t pt-4">${analysis.analysisResult}</div>
                `;
                
                document.getElementById('analysisModal').classList.remove('hidden');
            } catch (error) {
                console.error('Error fetching analysis:', error);
                alert('Error loading analysis details');
            }
        }

        async function deleteAnalysis(id) {
            if (confirm('Are you sure you want to delete this analysis?')) {
                try {
                    const response = await fetch(`/api/analysis/${id}`, {
                        method: 'DELETE'
                    });
                    
                    if (response.ok) {
                        location.reload();
                    } else {
                        alert('Error deleting analysis');
                    }
                } catch (error) {
                    console.error('Error deleting analysis:', error);
                    alert('Error deleting analysis');
                }
            }
        }

        function closeModal() {
            document.getElementById('analysisModal').classList.add('hidden');
        }

        // Close modal when clicking outside of it
        window.onclick = function(event) {
            const modal = document.getElementById('analysisModal');
            const isBackdropClick = event.target === modal;
            if (isBackdropClick) {
                modal.classList.add('hidden');
            }
        }
    </script>
</body>
</html>
