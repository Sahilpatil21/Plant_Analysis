<%- include("partials/head", { title: "Plant Analyzer | AI Plant Analysis" }) %>
<%- include("partials/navbar") %>

<section class="flex flex-col md:flex-row items-center justify-between px-10 py-20 max-w-7xl mx-auto">

  <!-- Left -->
  <div class="md:w-1/2">
    <h2 class="text-4xl md:text-5xl font-extrabold leading-tight">
      AI Powered <span class="text-green-600">Plant Analysis</span>
    </h2>

    <p class="mt-6 text-lg text-gray-600">
      Upload a plant image and get detailed insights about its species,
      characteristics, health condition, and care instructions using AI.
    </p>

    <div class="mt-8 flex gap-4">
      <a href="/register"
         class="bg-green-600 text-white px-6 py-3 rounded-lg text-lg hover:bg-green-700 transition">
        Explore 🌿
      </a>
    </div>
  </div>

  <!-- Right -->
  <div class="md:w-1/2 mt-12 md:mt-0 flex justify-center">
    <img
      src="https://images.unsplash.com/photo-1501004318641-b39e6451bec6"
      class="rounded-2xl shadow-lg w-[420px]"
      alt="Plant"
    />
  </div>

</section>

<section id="features" class="bg-white py-20">
  <div class="max-w-7xl mx-auto px-8">
    <h3 class="text-3xl font-bold text-center mb-12">
      What Can This App Do?
    </h3>

    <div class="grid md:grid-cols-3 gap-8">
      <div class="p-6 rounded-xl shadow hover:shadow-lg transition">
        <h4 class="text-xl font-semibold mb-3">🌿 Plant Identification</h4>
        <p class="text-gray-600">
          Identify plant species accurately using AI image analysis.
        </p>
      </div>

      <div class="p-6 rounded-xl shadow hover:shadow-lg transition">
        <h4 class="text-xl font-semibold mb-3">🧪 Health Analysis</h4>
        <p class="text-gray-600">
          Detect health conditions and get useful recommendations.
        </p>
      </div>

      <div class="p-6 rounded-xl shadow hover:shadow-lg transition">
        <h4 class="text-xl font-semibold mb-3">📘 Care Guide</h4>
        <p class="text-gray-600">
          Learn watering, sunlight, soil, and plant care tips.
        </p>
      </div>
    </div>
  </div>
</section>

<%- include("partials/footer") %>

